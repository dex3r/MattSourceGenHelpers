<Project Sdk="Microsoft.NET.Sdk">

    <PropertyGroup>
        <LangVersion>default</LangVersion>
        <ImplicitUsings>enable</ImplicitUsings>
        <Nullable>enable</Nullable>
        <GeneratePackageOnBuild>true</GeneratePackageOnBuild>
        <Version>0.1.1-alpha</Version>
        <Title>Easy Source Generators Abstractions</Title>
        <Description>Abstractions used by EasySourceGenerators.</Description>
        <Authors>Matt Krzaczek</Authors>
        <PackageProjectUrl>https://github.com/dex3r/EasySourceGenerators</PackageProjectUrl>
        <RepositoryUrl>https://github.com/dex3r/EasySourceGenerators</RepositoryUrl>
        <PackageReadmeFile>README.md</PackageReadmeFile>
        <TargetFramework>net8.0</TargetFramework>
    </PropertyGroup>

    <ItemGroup>
      <None Include="..\README.md" Pack="true" PackagePath="\" />
    </ItemGroup>

</Project>
